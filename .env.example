# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key
DJANGO_SETTINGS_MODULE=ndozi_climate.settings.production
ALLOWED_HOSTS=ndoziclimate.org,www.ndoziclimate.org
CORS_ALLOWED_ORIGINS=https://ndoziclimate.org

# ── MySQL (must match docker-compose.yml values) ─────────────────────────────
MYSQL_ROOT_PASSWORD=change-this-root-password
DB_NAME=ndozi_climate
DB_USER=ndozi_user
DB_PASSWORD=change-this-db-password
# DB_HOST and DB_PORT are set by docker-compose; leave these commented out:
# DB_HOST=db
# DB_PORT=3306

# ── Redis (set by docker-compose; leave commented out unless running bare) ───
# REDIS_URL=redis://redis:6379/1

# ── AI / Google Earth Engine ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEE_SERVICE_ACCOUNT_KEY=/run/gee/service-account.json
GEE_PROJECT_ID=your-gee-project-id

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Ndozi Climate <noreply@ndoziclimate.org>
ADMIN_EMAIL=admin@ndoziclimate.org
