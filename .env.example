DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=ndozi_climate.settings.development

ANTHROPIC_API_KEY=sk-ant-...
GEE_SERVICE_ACCOUNT_KEY=/path/to/gee-service-account.json
GEE_PROJECT_ID=your-gee-project-id

# Production only
DB_NAME=ndozi_climate
DB_USER=ndozi_user
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

REDIS_URL=redis://127.0.0.1:6379/1
ALLOWED_HOSTS=ndoziclimate.org,www.ndoziclimate.org
CORS_ALLOWED_ORIGINS=https://ndoziclimate.org
